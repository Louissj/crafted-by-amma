generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id                String   @id @default(cuid())
  name              String
  phone             String
  email             String?
  products          Json     // ["millet-malt", "instant-dosa"]
  quantity          String   // "250g", "500g", "1kg", "2kg"
  city              String
  address           String
  pincode           String?
  paymentScreenshot String?  // file path
  paymentMethod     String?
  notes             String?
  status            String   @default("pending")
  totalAmount       Float?
  deliveryCharge    Float?   @default(0)
  isKarnataka       Boolean  @default(false)
  count             Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([phone])
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Offer {
  id        String   @id @default(cuid())
  icon      String   @default("✨")
  text      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliverySettings {
  id           String   @id @default("singleton")
  baseCharge   Float    @default(50)
  freeAboveAmt Float    @default(350)
  karnatakFree Boolean  @default(true)
  note         String   @default("Free delivery in Karnataka for orders \u20b9350+")
  updatedAt    DateTime @updatedAt
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String   // 'page_view' | 'cart_view' | 'add_to_cart' | 'checkout_start' | 'order_placed'
  sessionId String?  // anonymous browser fingerprint
  productId String?  // for product-level events
  packSize  String?  // for add_to_cart
  page      String?  // for page_view
  metadata  Json?    // any extra context
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([sessionId])
  @@index([productId])
}

model Review {
  id        String   @id @default(cuid())
  name      String
  place     String
  rating    Int      // 1–5
  text      String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([approved])
  @@index([createdAt])
}

model Product {
  id          String   @id
  name        String
  shortName   String
  badge       String   @default("")
  description String
  ingredients String
  usage       Json     // [{ type: string, instructions: string }]
  prices      Json     // { "250g": 110, "500g": 190, ... }
  images      Json     @default("[]") // ["/images/..."]
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
