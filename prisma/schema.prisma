generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id                String   @id @default(cuid())
  name              String
  phone             String
  email             String?
  products          Json     // ["millet-malt", "instant-dosa"]
  quantity          String   // "250g", "500g", "1kg", "2kg"
  city              String
  address           String
  pincode           String?
  paymentScreenshot String?  // file path
  paymentMethod     String?
  notes             String?
  status            String   @default("pending")
  totalAmount       Float?
  deliveryCharge    Float?   @default(0)
  isKarnataka       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([phone])
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Offer {
  id        String   @id @default(cuid())
  icon      String   @default("✨")
  text      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeliverySettings {
  id           String   @id @default("singleton")
  baseCharge   Float    @default(50)
  freeAboveAmt Float    @default(350)
  karnatakFree Boolean  @default(true)
  note         String   @default("Free delivery in Karnataka for orders \u20b9350+")
  updatedAt    DateTime @updatedAt
}
